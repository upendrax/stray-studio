---
import Layout from "../components/Layout.astro";
---

<Layout title="Not found">
  <div class="u-container flex flex-col items-center py-32 text-center">
    <span class="u-label">Error 404</span>
    <h1 class="mt-3 text-5xl">Nothing here</h1>
    <p class="mt-3 max-w-sm text-muted">The page or product you're after may have sold out or moved.</p>
    <a href="/products" class="mt-8 inline-flex items-center gap-2 rounded-[var(--radius-brand)] bg-accent px-5 py-3 text-sm font-medium text-accent-ink">
      Back to shop <span aria-hidden="true">→</span>
    </a>
  </div>
</Layout>
