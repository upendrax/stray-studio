---
import { SITE } from "../lib/config";
import type { Category, StoreSettings } from "../lib/types";

interface Props {
  storeName: string;
  settings: StoreSettings | null;
  categories: Category[];
}
const { storeName, settings, categories } = Astro.props;
const nav = categories.filter((c) => !c.parentId && c.productCount > 0).slice(0, 6);
const year = 2026; // Date is unavailable at build in Workers preview; stamped yearly.
---

<footer class="mt-24 border-t border-line">
  <div class="u-container grid gap-10 py-14 sm:grid-cols-2 lg:grid-cols-4">
    <div class="lg:col-span-2">
      <div class="font-display text-lg font-bold">{storeName}</div>
      <p class="mt-3 max-w-xs text-sm text-muted">{SITE.footerNote}</p>
      {settings?.email && (
        <a href={`mailto:${settings.email}`} class="mt-4 inline-block text-sm">
          <span class="u-underline">{settings.email}</span>
        </a>
      )}
    </div>

    <div>
      <div class="u-label">Shop</div>
      <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/products" class="text-muted hover:text-ink">All products</a></li>
        {nav.map((c) => (
          <li><a href={`/collections/${c.slug}`} class="text-muted hover:text-ink">{c.name}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <div class="u-label">Contact</div>
      <ul class="mt-4 space-y-2 text-sm text-muted">
        {settings?.phone && <li>{settings.phone}</li>}
        {settings?.address && <li class="whitespace-pre-line">{settings.address}</li>}
      </ul>
    </div>
  </div>

  <div class="border-t border-line">
    <div class="u-container flex flex-col gap-1 py-5 sm:flex-row sm:items-center sm:justify-between">
      <span class="u-label">© {year} {storeName}</span>
      <span class="u-label">Powered by Stray Studio</span>
    </div>
  </div>
</footer>
