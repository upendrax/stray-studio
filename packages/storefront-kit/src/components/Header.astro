---
import type { Category } from "../lib/types";

interface Props {
  storeName: string;
  categories: Category[];
}
const { storeName, categories } = Astro.props;

// Top-level, non-empty categories become the primary nav.
const nav = categories
  .filter((c) => !c.parentId && c.productCount > 0)
  .slice(0, 6);
---

<header class="sticky top-0 z-40 border-b border-line bg-paper/85 backdrop-blur-md">
  <div class="u-container flex h-16 items-center justify-between gap-6">
    <a href="/" class="shrink-0">
      <span class="font-display text-lg font-bold tracking-tight">{storeName}</span>
    </a>

    <nav class="hidden items-center gap-7 md:flex">
      <a href="/products" class="text-sm font-medium"><span class="u-underline">Shop all</span></a>
      {nav.map((c) => (
        <a href={`/collections/${c.slug}`} class="text-sm font-medium">
          <span class="u-underline">{c.name}</span>
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
    <a href="/account" class="grid size-9 place-items-center rounded-[var(--radius-brand)] border border-line transition-colors hover:border-ink" aria-label="Account">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
        <circle cx="12" cy="8" r="3.2" />
        <path d="M5 20a7 7 0 0 1 14 0" />
      </svg>
    </a>
    <a
      href="/cart"
      class="group flex items-center gap-2 rounded-[var(--radius-brand)] border border-line px-3 py-1.5 transition-colors hover:border-ink"
      aria-label="Shopping bag"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
        <path d="M6 7h12l-1 13H7L6 7Z" />
        <path d="M9 7a3 3 0 0 1 6 0" />
      </svg>
      <span class="u-label !text-ink">Bag</span>
      <span
        data-bag-count
        hidden
        class="min-w-4 rounded-full bg-accent px-1 text-center font-mono text-[0.625rem] leading-4 text-accent-ink"
      >0</span>
    </a>
    </div>
  </div>

  {nav.length > 0 && (
    <nav class="u-container flex gap-5 overflow-x-auto border-t border-line py-2 md:hidden">
      <a href="/products" class="whitespace-nowrap text-sm font-medium">Shop all</a>
      {nav.map((c) => (
        <a href={`/collections/${c.slug}`} class="whitespace-nowrap text-sm font-medium">{c.name}</a>
      ))}
    </nav>
  )}
</header>
